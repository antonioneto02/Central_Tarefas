<div class="note-card note-color-<%= nota.cor || 'default' %> <%= nota.fixado ? 'pinned' : '' %>"
     data-nota-id="<%= nota.id %>"
     data-tags="<%= nota.etiquetas_nomes || '' %>">

  <% if (nota.titulo) { %>
    <div class="note-title"><%= nota.titulo %></div>
  <% } %>

  <% if (nota.conteudo) { %>
    <div class="note-content"><%= nota.conteudo.length > 300 ? nota.conteudo.substring(0,300) + '…' : nota.conteudo %></div>
  <% } %>

  <% if (nota.etiquetas_nomes) { %>
    <div class="note-tags">
      <% nota.etiquetas_nomes.split(', ').forEach(function(tag) { %>
        <span class="note-tag"><%= tag %></span>
      <% }); %>
    </div>
  <% } %>

  <div class="note-footer">
    <span class="note-date">
      <%= new Date(nota.data_atualizacao).toLocaleDateString('pt-BR') %>
    </span>
    <div class="note-actions">
      <button class="note-action-btn" title="<%= nota.fixado ? 'Desafixar' : 'Fixar' %>"
              onclick="fixarNota(<%= nota.id %>, this)">
        <i class="bi bi-pin<%= nota.fixado ? '-fill' : '' %>"></i>
      </button>
      <button class="note-action-btn" title="Editar"
              onclick="editarNota(<%= nota.id %>)">
        <i class="bi bi-pencil"></i>
      </button>
      <button class="note-action-btn" title="Arquivar"
              onclick="arquivarNota(<%= nota.id %>)">
        <i class="bi bi-archive"></i>
      </button>
      <button class="note-action-btn" title="Excluir"
              onclick="excluirNota(<%= nota.id %>)">
        <i class="bi bi-trash"></i>
      </button>
    </div>
  </div>
</div>
